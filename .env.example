# ============================================================
# Djup Terminal — environment configuration
# ============================================================
# Copy to `.env` (root) for shared values, and to `backend/.env` for
# server-only secrets. Endpoints gracefully degrade when keys are missing.

# ──────────────── BACKEND ────────────────
# Drop the keys below into  backend/.env

# Macro — FRED (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Newswire — graceful fallback chain (NewsAPI -> GNews -> Guardian)
NEWSAPI_KEY=
GNEWS_API_KEY=
# Guardian works with the literal value `test` for low-volume use:
GUARDIAN_API_KEY=test

# AI — Gemini (Google AI Studio): https://aistudio.google.com/app/apikey
# Enables /api/ai/analyze (page commentary) and /api/ai/summarize-news
# (newswire digest button). Without it both endpoints return a graceful
# `available: false` payload and the UI shows a hint.
GEMINI_API_KEY=
# Optional: override default model. Defaults to gemini-2.0-flash (fast, cheap).
GEMINI_MODEL=gemini-2.0-flash

# Legacy AI for /api/commentary/latest (OpenAI). Optional.
OPENAI_API_KEY=

# SEC EDGAR — no key, just identify yourself per SEC policy.
SEC_USER_AGENT=Djup-Terminal/1.4 contact@your-domain.example

# DB & CORS
DATABASE_URL=
ENV=development
FRONTEND_URL=

# ──────────────── FRONTEND ────────────────
# These end up in  frontend/.env  (or just the root .env consumed by Vite).
# The `VITE_` prefix is required for Vite to expose them to the browser.

# Backend base URL (used when frontend is deployed separately).
VITE_API_URL=http://localhost:8000/api

# Supabase — PUBLISHABLE key only. Never the service-role key.
# Project URL + publishable key from your Supabase project settings.
VITE_SUPABASE_URL=https://pfpuccklbmlxvivdgjel.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XNLE3NkIb5vod0lesINgFw_0DXHz_9j

# After cloning the repo, run  supabase_setup.sql  in your Supabase
# SQL editor once to create the `profiles` and `user_events` tables
# with row-level-security policies.
