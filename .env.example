# ============================================================
# Djup Terminal — environment configuration
# ============================================================
# Required: copy this file to `.env` and fill in any keys you have.
# Endpoints will gracefully degrade if a key is missing.

# --- Macro ---
# FRED — free, no rate limit issues for normal use.
# Sign up at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Newswire (fallback chain: NewsAPI -> GNews -> Guardian) ---
# https://newsapi.org/register
NEWSAPI_KEY=
# https://gnews.io/register
GNEWS_API_KEY=
# https://open-platform.theguardian.com/access/  (or leave blank to use the public "test" key)
GUARDIAN_API_KEY=

# --- Optional: AI commentary ---
# Used by /api/commentary/latest. Without it, AI commentary panel shows fallback.
OPENAI_API_KEY=

# --- SEC EDGAR (no key needed; just identify yourself per SEC policy) ---
SEC_USER_AGENT=Djup-Terminal/1.4 contact@your-domain.example

# --- Backend runtime ---
# Defaults to local sqlite; set DATABASE_URL for a managed postgres.
DATABASE_URL=
# Production vs development CORS handling.
ENV=development
# Frontend URL (only used in production for strict CORS).
FRONTEND_URL=

# --- Frontend ---
# When deploying the frontend separately, set this to the backend's base URL.
VITE_API_URL=http://localhost:8000/api
